@model IEnumerable<PARCIAL_PROGRA.Models.Curso>

@{
    ViewData["Title"] = "Panel de Coordinador";
}

<h1>Panel de Coordinador</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<p>
    <a asp-action="Nuevo" class="btn btn-primary">Crear Nuevo Curso</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Créditos</th>
            <th>Cupo</th>
            <th>Horario</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var curso in Model)
        {
            <tr>
                <td>@curso.Codigo</td>
                <td>@curso.Nombre</td>
                <td>@curso.Creditos</td>
                <td>@curso.CupoMaximo</td>
                <td>@curso.HorarioInicio.ToString(@"hh\:mm") - @curso.HorarioFin.ToString(@"hh\:mm")</td>
                <td>
                    <span class="badge bg-@(curso.Activo ? "success" : "secondary")">
                        @(curso.Activo ? "Activo" : "Inactivo")
                    </span>
                </td>
                <td>
                    <a asp-action="Editar" asp-route-id="@curso.Id" class="btn btn-sm btn-warning">Editar</a>
                    @if (curso.Activo)
                    {
                        <a asp-action="Desactivar" asp-route-id="@curso.Id" class="btn btn-sm btn-danger" onclick="return confirm('¿Está seguro de desactivar este curso?')">Desactivar</a>
                    }
                    <a asp-action="Matriculas" asp-route-cursoId="@curso.Id" class="btn btn-sm btn-info">Ver Matrículas</a>
                </td>
            </tr>
        }
    </tbody>
</table>